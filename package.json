{
  "name": "kniha-jizd",
  "version": "1.0.0",
  "description": "Lokální offline aplikace pro vedení knihy jízd.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "web:dev": "vite --host 127.0.0.1",
    "web:build": "vite build",
    "build": "npm run web:build",
    "desktop:build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "start": "electron .",
    "dist": "npm run desktop:build && electron-builder --win nsis",
    "export:sample": "tsx scripts/create-sample-export.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "cz.lokalni.knihajizd",
    "productName": "Kniha jízd",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
